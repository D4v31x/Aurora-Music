{"nodes": [{"id": "readme", "label": "Aurora Music README", "file_type": "document", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_aurora_music_app", "label": "Aurora Music App", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Android-focused Flutter music player (version 1.3.6+22) targeting on-device playback with Material You design. minSdk 29 (Android 10), targetSdk 35. Licensed under GNU GPLv3. Package name: aurora_music_v01."}, {"id": "concept_provider_services_arch", "label": "Provider + Services Architecture", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "App uses Provider for global state management and a dedicated services layer for business logic (audio, lyrics, caching, suggestions, metadata, Bluetooth). UI is split into screens (high-level flows) and widgets (reusable components). Features organized under lib/features/, shared code in lib/shared/, infrastructure in lib/core/."}, {"id": "feature_local_library", "label": "Local Library Scanning", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Scans device MediaStore via on_audio_query. Supports songs, albums, artists. Requires READ_MEDIA_AUDIO (Android 13+) or READ_EXTERNAL_STORAGE (Android 12-)."}, {"id": "feature_background_playback", "label": "Background Audio Playback", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Uses audio_service for Android media session and background service + just_audio as the playback engine. Supports gapless playback, playback speed, shuffle, repeat, and sleep timer. Requires FOREGROUND_SERVICE_MEDIA_PLAYBACK and WAKE_LOCK."}, {"id": "feature_synced_lyrics", "label": "Synced Lyrics (LRCLIB)", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Fetches timed lyrics from LRCLIB API over HTTP. Caches results locally. Full-screen lyrics view with sync offset controls. Batch download tool for offline use."}, {"id": "feature_smart_recommendations", "label": "Smart Recommendations", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Suggestions based on listening history using time-of-day and day-of-week patterns. Stored and queried locally."}, {"id": "feature_dynamic_theming", "label": "Dynamic Color Theming", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Material You dynamic color via dynamic_color package plus palette_generator for artwork-based color extraction. Blurred backgrounds and artwork caching for visual richness."}, {"id": "feature_metadata_editor", "label": "Metadata Editor", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Tag reading/writing via audiotags. Auto-tag suggestions from Deezer/iTunes. On Android 10+ uses MediaStore ContentResolver via platform channel \u2014 no MANAGE_EXTERNAL_STORAGE required."}], "edges": [{"source": "readme", "target": "concept_aurora_music_app", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": null, "weight": 1.0}, {"source": "readme", "target": "concept_provider_service